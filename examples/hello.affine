--
-- PseudoScript face. Distinctive features exercised:
-- function ... do ... end blocks, `--` comments, `set X to Y` bindings,
-- `output X` I/O, multi-statement function bodies.
-- face: pseudoscript

effect IO {
  fn println(s: String) -> ();
}

function main() -{IO}-> () do
    set greeting to "Hello, PseudoScript!"
    output greeting
end
